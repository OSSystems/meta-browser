index 9664858a93..259751f93c 100644
--- a/sandbox/linux/system_headers/mips_linux_syscalls.h
+++ b/sandbox/linux/system_headers/mips_linux_syscalls.h
@@ -1757,4 +1757,8 @@
 #define __NR_mseal (__NR_Linux + 462)
 #endif
 
